# 环境
VITE_APP_ENV=development

# 项目名称
VITE_APP_TITLE=fastcloud

# 项目版本
VITE_APP_VERSION=2.0.0

# 网络请求公用地址，根据实际部署情况修改
# VITE_API_BASE_URL=https://service.FastCloud.com
VITE_API_BASE_URL=http://127.0.0.1:8001

# 代理前缀
VITE_APP_BASE_API=/api/v1

# 应用端口
VITE_APP_PORT=5180

# 超时时间
VITE_TIMEOUT=10000

# WebSocket 端点（不配置则关闭），ai对话需要配置
# VITE_APP_WS_ENDPOINT=wss://service.FastCloud.com
VITE_APP_WS_ENDPOINT=ws://127.0.0.1:8001
